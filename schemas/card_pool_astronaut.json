      { "id": "astro_a_3", "group": "A", "text": "任務達成", "condition": "general" },
      { "id": "astro_a_4", "group": "A", "text": "軌道穩定", "condition": "short_session" },
      { "id": "astro_a_5", "group": "A", "text": "一圈又一圈，你做到了", "condition": "long_session" },
      { "id": "astro_b_6", "group": "B", "text": "返航時間到了", "condition": "general" },
