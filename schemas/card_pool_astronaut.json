      { "id": "astro_c_12", "group": "C", "text": "飄一下也行", "condition": "general" },
      { "id": "astro_c_13", "group": "C", "text": "安靜的人，最像星星", "condition": "general" },
      { "id": "astro_c_14", "group": "C", "text": "又一次信號，收到", "condition": "cumulative_5_days" },
